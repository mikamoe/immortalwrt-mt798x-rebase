#!/usr/bin/ucode
import * as fs from 'fs';
import * as l1parser from 'l1parser';

import { setup, down } from 'mtwifi.config';
import { log } from 'mtwifi.utils';

if (length(ARGV) > 0) {
	let action = ARGV[0];
	let devname = ARGV[1];

	let l1 = l1parser.open();
	let all_devs = l1.getall();

	switch (action) {
		case "setup":
			let input = fs.readfile("/dev/stdin");
			log.debug(`[UCI] ${input}`);
			if (input) {
				setup(json(input), all_devs);
			}
			break;
		case "down":
			down(devname, all_devs);
			break;
	}
}
